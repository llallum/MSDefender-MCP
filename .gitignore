node_modules/
# Note: do NOT add a bare "src/" ignore here — it would hide the actual
# source tree under native-messaging/src/. If you need to ignore a per-user
# generated src/ artifact, use a more specific path.
*.log
error.log
.roo/
.vscode/
trash/
Previous/
install.bat
install.js
manifest.json
package.json
package-lock.json
run.bat

# Chrome extension signing key and build artifacts — never commit the
# private key (dist.pem). dist/ and dist.crx are build outputs produced
# by `npm run build` / "Pack extension" and are reproducible from source.
browser-extension/dist.pem
browser-extension/dist.crx
browser-extension/dist/

# Native messaging host runtime artifacts (per-user data, session cache, DuckDB)
# These are generated at runtime and must never be committed.
native-messaging/src/server/defender.json
native-messaging/src/duckdb/

# Work-in-progress file scheduled to land in a separate commit; remove this
# line once the streamable-HTTP MCP transport lands on main.
native-messaging/src/client/mcp-http-server.js
